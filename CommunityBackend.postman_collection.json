  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/register"
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Frontend Tester\",\n  \"email\": \"tester@example.com\",\n  \"password\": \"password123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.accessToken) {",
                  "  pm.environment.set('accessToken', json.accessToken);",
                  "}",
                  "if (json.user && json.user.id) {",
                  "  pm.environment.set('userId', json.user.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
